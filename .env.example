# Vite dev uses HTTPS by default (@vitejs/plugin-basic-ssl) so Web Crypto works for Keycloak on LAN IPs.
# Open https://<host>:5173 (not http). Set VITE_DEV_HTTPS=0 to force plain HTTP in environments
# where Keycloak/client config is intentionally set to http://<host>:5173.
# Optional: VITE_DEV_SSL_DOMAINS=mydev.local  (and map mydev.local in /etc/hosts)
# Optional: VITE_DEV_SSL_CERT=... VITE_DEV_SSL_KEY=...  (defaults to ./cert.pem + ./key.pem if present)
# Do not use `npx serve -s dist` for production-like runs: `-s` returns index.html for /api.
# After `npm run build`, use `npm run serve:dist` (vite preview on :5173 with /api → Frappe proxy).

VITE_FRAPPE_BASE_URL=http://10.150.48.12:8001
# true = Frappe API calls use this site’s origin (/api/...); dev/preview proxy and nginx can forward to VITE_FRAPPE_BASE_URL.
# Use this when a direct VITE_FRAPPE_BASE_URL in the browser fails (CORS, HTTPS vs HTTP mixed content).
# VITE_FRAPPE_SAME_ORIGIN_API=true
# Optional comma-separated extra browser origins allowed to postMessage this portal on ERP logout
# (in addition to VITE_FRAPPE_BASE_URL / VITE_FRAPPE_URL). Example: http://other-host:8001
# VITE_FRAPPE_LOGOUT_MESSAGE_ORIGINS=
#
# When users open ERP from this portal, the new tab keeps window.opener so Frappe can notify the portal.
# Add a Frappe Client Script on logout (target origin = this portal, same as VITE_KEYCLOAK_REDIRECT_URI host):
#   if (window.opener && !window.opener.closed) {
#     window.opener.postMessage('kalyan-portal:sso-ended', 'https://YOUR_PORTAL_ORIGIN')
#   }
# Optional object form: window.opener.postMessage({ type: 'kalyan-portal:sso-ended' }, 'https://...')
#
# For multiple ERP tabs on the same Frappe host, add a Client Script (all pages) to react to central logout:
#   window.addEventListener('storage', (e) => {
#     if (e.key === 'kalyan-frappe:sso-ended' && e.newValue) location.replace('/login')
#   })
# The portal sets that key via sso_logout redirect_to=/applications?no_access=1; Frappe sso_logout should
# also set localStorage kalyan-frappe:sso-ended on the ERP origin when ending sessions (if not, only the
# navigated tab logs out until the user refreshes other tabs).
#
# Optional token auth for Frappe API calls (needed when no Frappe session cookie)
# For API key/secret use: token <api_key>:<api_secret>
# VITE_FRAPPE_TOKEN=your_api_key:your_api_secret
# VITE_FRAPPE_TOKEN_TYPE=token
FRAPPE_WEBSERVER_PORT=8001
VITE_KEYCLOAK_URL=http://10.150.48.12:8080
VITE_KEYCLOAK_REALM=kalyan
VITE_KEYCLOAK_CLIENT_ID=kalyan
VITE_KEYCLOAK_REDIRECT_URI=https://localhost:5173/applications
# Keycloak post-logout + Frappe sso_logout redirect_to (must match Keycloak "Valid post logout redirect URIs").
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=https://localhost:5173/applications?no_access=1
# Frappe sso_logout example (redirect_to must match VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI):
#   https://<frappe-host>:8001/api/method/keycloak_integration.utils.sso_logout?redirect_to=https%3A%2F%2F<portal-host>%3A5173%2Fapplications%3Fno_access%3D1
#
# Detect Keycloak SSO logout from other apps/tabs via a hidden session iframe (on by default; set false to disable).
# VITE_KEYCLOAK_CHECK_LOGIN_IFRAME=true
# Seconds between iframe session checks (min 3). Only used when CHECK_LOGIN_IFRAME is true.
VITE_KEYCLOAK_CHECK_LOGIN_IFRAME_INTERVAL_SEC=5
# Periodic forced token refresh in ms (min 15000). When unset, defaults to 45000. Set 0/false/off to disable.
# Notices dead Keycloak sessions even if iframe checks fail. Lower (e.g. 30000) if the main tab feels stale after ERP logout.
VITE_KEYCLOAK_SSO_PROBE_INTERVAL_MS=120000
VITE_DEV_HTTPS=
VITE_KEYCLOAK_AVAILABILITY_TIMEOUT_MS=5000
# Portal apps (HR, Sales, Warehouse, Finance) are now configured in Frappe desk → KJI Portal Application.
# The React portal fetches them at runtime via GET /api/method/keycloak_integration.utils.get_portal_applications.
# No per-app env vars are needed here.
# Comma-separated Keycloak roles required to view Users list.
# Default in app is System Manager when this value is empty.
VITE_USER_LIST_REQUIRED_ROLES=System Manager
# Optional filter for keycloak_integration.utils.get_central_portal_users (Active, Inactive, Revoked).
# VITE_CENTRAL_PORTAL_USERS_STATUS=Active
