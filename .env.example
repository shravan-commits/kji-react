# ---------------------------------------------------------------------------
# Frontend environment (Vite)
# Copy to ".env" or ".env.local" and set real values.
# Only variables prefixed with VITE_ are exposed to the browser.
#
# UI flow (see src/App.tsx):
#   1) http://localhost:5173 — Keycloak hosted login (Authorization Code + PKCE)
#   2) Dashboard — http://localhost:5173/applications
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Portal states (optional UI switches)
# ---------------------------------------------------------------------------
# Scheduled maintenance: replaces Applications + Users content with maintenance screen.
# VITE_MAINTENANCE_MODE=true
# VITE_MAINTENANCE_DURATION=4 Hours
# VITE_MAINTENANCE_UNTIL=Until 11:00 PM IST
# VITE_MAINTENANCE_TYPE=Scheduled
# VITE_MAINTENANCE_SUBTYPE=Planned Upgrade

# No-access screen when you have zero active applications, or force via env:
# VITE_NO_ACCESS_MODE=true
# VITE_PORTAL_UID=PU-2024-001234
# VITE_PORTAL_DISPLAY_NAME=John Doe
# VITE_PORTAL_DISPLAY_EMAIL=john.doe@company.com
# mailto: or https: link for “Contact Administrator”
# VITE_ADMIN_CONTACT_URL=mailto:admin@example.com

# ---------------------------------------------------------------------------
# Frappe / ERPNext (User list API via frappe-react-sdk; separate from portal sign-in)
# ---------------------------------------------------------------------------
# Public site URL (no trailing slash). Backend for SDK calls when not using dev proxy.
#
# docker-compose.yml in this repo publishes ERPNext nginx on host port 8080.
# Local bench without Docker often uses http://localhost:8000 .
VITE_FRAPPE_BASE_URL=http://localhost:8080

# Optional: force the browser (SDK + auth) to call this origin directly. In dev, omit
# so FrappeProvider uses relative URLs and vite.config proxy sends /api to Frappe.
# Production example:
# VITE_FRAPPE_URL=https://erp.example.com

# Optional: realtime (Frappe v15+). Set all three to enable the SDK socket client.
# VITE_FRAPPE_ENABLE_SOCKET=true
# VITE_SOCKET_PORT=9000
# VITE_SITE_NAME=yoursite.localhost

# Vite dev proxy (proxyOptions.ts): port where Frappe/ERPNext listens on the host.
# Use 8080 with docker-compose nginx; use 8000 for a typical local bench (or omit to auto-detect).
FRAPPE_WEBSERVER_PORT=8080

# ---------------------------------------------------------------------------
# Keycloak (hosted login page — Authorization Code + PKCE from the SPA)
# ---------------------------------------------------------------------------
# docker-compose exposes Keycloak on host 8081 (maps to container 8080).
# No trailing slash for Keycloak 17+ (no /auth in the base URL).
# In Vite dev, if this is omitted, the app defaults to http://localhost:8081 .
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=your-realm
# Must be a *public* client with Standard flow; not confidential.
VITE_KEYCLOAK_CLIENT_ID=your-spa-client-id

# In Keycloak Admin: "Valid redirect URIs" and "Web origins" must include exactly:
#   http://localhost:5173/applications
# (and production URLs as needed). Root http://localhost:5173/ is optional for logout.

# After successful login at http://localhost:8081, Keycloak redirects here (exact match required).
# If unset in Vite dev, the app defaults to http://localhost:5173/applications .
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173/applications
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/

# ---------------------------------------------------------------------------
# Integrated apps — "Open" on application cards (active apps only)
# ---------------------------------------------------------------------------
VITE_APP_HR_URL=https://hr.example.com
VITE_APP_WAREHOUSE_URL=https://warehouse.example.com
VITE_APP_SALES_URL=https://sales.example.com
VITE_APP_FINANCE_URL=https://finance.example.com

# ---------------------------------------------------------------------------
# Deploy
# ---------------------------------------------------------------------------
# Build with VITE_* set, then serve dist/ — see deploy/nginx-kalyan-auth.conf
# DOCKER_WEB_PORT=8080
