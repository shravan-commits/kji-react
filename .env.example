# ---------------------------------------------------------------------------
# Frontend environment (Vite)
# Copy to ".env" or ".env.local" and set real values.
# Only variables prefixed with VITE_ are exposed to the browser.
# ---------------------------------------------------------------------------

# Temporary UI-only demo: skip Frappe + Keycloak (portal loads without backends).
# Set false or remove for production / real integration.
# VITE_DEMO_MODE=true

# ---------------------------------------------------------------------------
# Portal states (optional UI switches)
# ---------------------------------------------------------------------------
# Scheduled maintenance: replaces Applications + Users content with maintenance screen.
# VITE_MAINTENANCE_MODE=true
# VITE_MAINTENANCE_DURATION=4 Hours
# VITE_MAINTENANCE_UNTIL=Until 11:00 PM IST
# VITE_MAINTENANCE_TYPE=Scheduled
# VITE_MAINTENANCE_SUBTYPE=Planned Upgrade

# No-access screen when user has zero active applications, or force for demos:
# VITE_NO_ACCESS_MODE=true
# VITE_PORTAL_UID=PU-2024-001234
# VITE_PORTAL_DISPLAY_NAME=John Doe
# VITE_PORTAL_DISPLAY_EMAIL=john.doe@company.com
# mailto: or https: link for “Contact Administrator”
# VITE_ADMIN_CONTACT_URL=mailto:admin@example.com

# ---------------------------------------------------------------------------
# Frappe + frappe-react-sdk (see Doppio SPA / Mint frontend patterns)
# ---------------------------------------------------------------------------
# Development: run `npm run dev` with a local bench — Vite proxies /api, /app, etc.
# (proxyOptions.ts). Use empty SDK URL (default in dev via frappeSdk.ts) so calls
# go through the proxy and session cookies match.
#
# Override SDK base URL if needed (e.g. direct calls without proxy):
# VITE_FRAPPE_URL=http://localhost:8000
#
# Production build served on a different host than Frappe: set the public Frappe site URL.
# VITE_FRAPPE_BASE_URL=https://erp.example.com

# When not using the proxy, site URL for redirects and legacy helpers. No trailing slash.
VITE_FRAPPE_BASE_URL=http://localhost:8000

# Optional: frappe-react-sdk socket (Frappe v15+). Enable explicitly or set both name + port.
# VITE_FRAPPE_ENABLE_SOCKET=true
# VITE_SOCKET_PORT=9000
# VITE_SITE_NAME=yoursite.localhost

# Optional: bench webserver port if sites/common_site_config.json is not discoverable from this folder.
# FRAPPE_WEBSERVER_PORT=8000

# Optional. If unset, unauthenticated users are sent to:
#   {VITE_FRAPPE_BASE_URL}/login?redirect-to=<this app's current URL>
# Use this when Frappe login lives at a different path or host.
# VITE_FRAPPE_LOGIN_URL=https://erp.example.com/login

# ---------------------------------------------------------------------------
# Keycloak (SSO after Frappe session exists)
# ---------------------------------------------------------------------------
# Keycloak server base URL (no trailing slash).
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=your-realm
# OIDC public client id for this SPA.
VITE_KEYCLOAK_CLIENT_ID=your-client-id

# Optional. If unset, the app uses window.location.origin (useful if dev port changes).
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# ---------------------------------------------------------------------------
# Integrated apps — "Open" on application cards (active apps only)
# ---------------------------------------------------------------------------
VITE_APP_HR_URL=https://hr.example.com
VITE_APP_WAREHOUSE_URL=https://warehouse.example.com
VITE_APP_SALES_URL=https://sales.example.com
VITE_APP_FINANCE_URL=https://finance.example.com

# ---------------------------------------------------------------------------
# Deploy
# ---------------------------------------------------------------------------
# Primary: build with this file’s VITE_* set, then serve dist/ with nginx —
#   see deploy/nginx-kalyan-auth.conf
# Optional later: Docker (Dockerfile + docker-compose.yml)
# DOCKER_WEB_PORT=8080
