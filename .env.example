# ---------------------------------------------------------------------------
# Frontend Environment Configuration
# Copy this file to ".env" and replace placeholder values.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Frappe (portal login step)
# ---------------------------------------------------------------------------
# Base URL of your Frappe backend. No trailing slash needed.
VITE_FRAPPE_BASE_URL=http://localhost:8000
# Optional: full login URL if not at {VITE_FRAPPE_BASE_URL}/login (redirect-to is appended).
# VITE_FRAPPE_LOGIN_URL=https://erp.example.com/login

# ---------------------------------------------------------------------------
# Keycloak (unified SSO step)
# ---------------------------------------------------------------------------
# Example: https://sso.example.com
VITE_KEYCLOAK_URL=http://localhost:8080
# Example: kalyan-realm
VITE_KEYCLOAK_REALM=your-realm
# Public client id configured in Keycloak for this frontend app.
VITE_KEYCLOAK_CLIENT_ID=your-client-id
# Must match a valid redirect URI configured in Keycloak client settings.
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173
# Where to return after Keycloak logout.
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# ---------------------------------------------------------------------------
# Integrated application launch URLs (opened after successful SSO)
# ---------------------------------------------------------------------------
VITE_APP_HR_URL=https://hr.example.com
VITE_APP_WAREHOUSE_URL=https://warehouse.example.com
VITE_APP_SALES_URL=https://sales.example.com
VITE_APP_FINANCE_URL=https://finance.example.com
