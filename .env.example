# ---------------------------------------------------------------------------
# Frontend environment (Vite)
# Copy to ".env" or ".env.local" and set real values.
# Only variables prefixed with VITE_ are exposed to the browser.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Frappe (session check + redirect when not logged in)
# ---------------------------------------------------------------------------
# Site URL for API calls: get_logged_user, logout, etc. No trailing slash.
VITE_FRAPPE_BASE_URL=http://localhost:8000

# Optional. If unset, unauthenticated users are sent to:
#   {VITE_FRAPPE_BASE_URL}/login?redirect-to=<this app's current URL>
# Use this when Frappe login lives at a different path or host.
# VITE_FRAPPE_LOGIN_URL=https://erp.example.com/login

# ---------------------------------------------------------------------------
# Keycloak (SSO after Frappe session exists)
# ---------------------------------------------------------------------------
# Keycloak server base URL (no trailing slash).
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=your-realm
# OIDC public client id for this SPA.
VITE_KEYCLOAK_CLIENT_ID=your-client-id

# Optional. If unset, the app uses window.location.origin (useful if dev port changes).
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# ---------------------------------------------------------------------------
# Integrated apps — "Open" on application cards (active apps only)
# ---------------------------------------------------------------------------
VITE_APP_HR_URL=https://hr.example.com
VITE_APP_WAREHOUSE_URL=https://warehouse.example.com
VITE_APP_SALES_URL=https://sales.example.com
VITE_APP_FINANCE_URL=https://finance.example.com
