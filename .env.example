VITE_FRAPPE_BASE_URL=http://10.150.48.12:8001
# Optional token auth for Frappe API calls (needed when no Frappe session cookie)
# For API key/secret use: token <api_key>:<api_secret>
# VITE_FRAPPE_TOKEN=your_api_key:your_api_secret
# VITE_FRAPPE_TOKEN_TYPE=token
FRAPPE_WEBSERVER_PORT=8001
VITE_KEYCLOAK_URL=http://10.150.48.12:8080
VITE_KEYCLOAK_REALM=kalyan
VITE_KEYCLOAK_CLIENT_ID=kalyan
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173/applications
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
VITE_KEYCLOAK_AVAILABILITY_TIMEOUT_MS=5000
VITE_APP_HR_URL=http://10.150.48.12:8001
# Comma-separated Keycloak roles required to open HR app.
# Example: VITE_APP_HR_REQUIRED_ROLES=frappe_user,hr_portal_user
VITE_APP_HR_REQUIRED_ROLES=
VITE_APP_WAREHOUSE_URL=https://warehouse.example.com
VITE_APP_WAREHOUSE_REQUIRED_ROLES=
VITE_APP_SALES_URL=https://sales.example.com
VITE_APP_SALES_REQUIRED_ROLES=
VITE_APP_FINANCE_URL=https://finance.example.com
VITE_APP_FINANCE_REQUIRED_ROLES=
